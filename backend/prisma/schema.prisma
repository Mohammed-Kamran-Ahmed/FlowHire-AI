datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String       @default("RECRUITER") // RECRUITER, INTERVIEWER, ADMIN
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  candidates   Candidate[]  @relation("RecruiterCandidates")
  interviews   Interview[]  @relation("InterviewerInterviews")
  evaluations  Evaluation[]
}

model Candidate {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?
  resumeUrl    String?
  resumeText   String?       // Stored resume text for AI parsing and insights
  currentStage String        @default("APPLIED") // APPLIED, SCREENING, TECH_INTERVIEW, MGMT_INTERVIEW, OFFER, HIRED, REJECTED
  status       String        @default("ACTIVE")  // ACTIVE, HIRED, REJECTED
  recruiterId  String
  recruiter    User          @relation("RecruiterCandidates", fields: [recruiterId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interviews   Interview[]
  evaluations  Evaluation[]
  aiAnalysis   AiAnalysis?
}

model Interview {
  id            String    @id @default(uuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  title         String    // e.g., "Technical Assessment", "System Design Interview"
  scheduledAt   DateTime
  status        String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  interviewerId String
  interviewer   User      @relation("InterviewerInterviews", fields: [interviewerId], references: [id])
  feedback      String?   // Interviewer notes
  rating        Int?      // Rating score out of 5
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Evaluation {
  id                 String    @id @default(uuid())
  candidateId        String
  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  technicalScore     Int       // 1 to 5
  communicationScore Int       // 1 to 5
  cultureScore       Int       // 1 to 5
  recommendation     String    // STRONG_REJECT, REJECT, NEUTRAL, HIRE, STRONG_HIRE
  comments           String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model AiAnalysis {
  id             String    @id @default(uuid())
  candidateId    String    @unique
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  summary        String    // AI-generated summary of the candidate's evaluations & profile
  strengths      String    // JSON string or structured text of key strengths
  weaknesses     String    // JSON string or structured text of key improvements needed
  recommendation String    // AI recommendation rating (HIRE, REJECT, CAUTION, etc.)
  matchScore     Int       // Job description matching score (0-100)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
